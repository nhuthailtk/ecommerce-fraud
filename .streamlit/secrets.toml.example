# Copy this file to `.streamlit/secrets.toml` (gitignored) and fill in your own
# values. Streamlit auto-loads secrets.toml; the Monitoring page reads
# `alert_webhook_url` to pre-fill the alert webhook field.
#
# You can also set the environment variable ALERT_WEBHOOK_URL instead.

# Slack / Discord / generic incoming webhook for drift-retrain alerts.
alert_webhook_url = "https://hooks.slack.com/services/XXXX/XXXX/XXXX"
