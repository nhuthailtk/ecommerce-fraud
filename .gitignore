# =====================================================================
# HEAVY dataset files stay OUT of git — regenerate via scripts/get_data.sh
# or ./train.sh full (see docs/data_setup.md). Model bundles (small, a few
# hundred KB) ARE committed so the repo is usable right after clone.
# =====================================================================
# Raw PaySim dataset (~471MB) — download from Kaggle into data/raw/
data/raw/*
!data/raw/.gitkeep

# Kaggle download archive left in the repo root (~178MB)
*.zip

# Big processed datasets (~550-590MB each) — regenerate: ./scripts/get_data.sh
data/processed/*.parquet

# Synthetic caches (regenerate on first run) — customer master + stand-in
data/synthetic/*
!data/synthetic/.gitkeep

# Large generated HTML report (~4MB) — regenerate: python monitoring/drift.py
monitoring/reports/*.html

# Runtime logs
logs/*.log
train.log
train_realistic.log

# Unrelated one-off script (different project's dataset download)
install_kaggle.py

# =====================================================================
# KEPT in git on purpose (small + useful after clone):
#   models/*.joblib                     (trained bundle — run infer.py/api right after clone)
#   data/processed/sample_preview.csv   (Streamlit demo runs without big files)
#   docs/figures/*.png, docs/*.md, monitoring/reports/*.md
# =====================================================================

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
scored.csv

# Secrets — Streamlit secrets (webhook URLs, tokens). NEVER commit.
.streamlit/secrets.toml
.env
